# PelagoDB presentation profile

# Core server
export PELAGO_FDB_CLUSTER=/usr/local/etc/foundationdb/fdb.cluster
export PELAGO_SITE_ID=1
export PELAGO_SITE_NAME=sf
export PELAGO_LISTEN_ADDR=127.0.0.1:27615
export RUST_LOG=info
export PELAGO_DEFAULT_DATABASE=default
export PELAGO_DEFAULT_NAMESPACE=vfx.show.001

# CLI defaults for presentation commands/smoke script
export PELAGO_DATABASE=default
export PELAGO_NAMESPACE=vfx.show.001

# Security
export PELAGO_AUTH_REQUIRED=false
# export PELAGO_API_KEYS='dev-admin-key:demo-admin'

# Cache
export PELAGO_CACHE_ENABLED=true

# Audit
export PELAGO_AUDIT_ENABLED=true
export PELAGO_AUDIT_RETENTION_DAYS=90

# Optional multi-site replication
# export PELAGO_REPLICATION_ENABLED=true
# export PELAGO_REPLICATION_PEERS='2=127.0.0.1:27616'

# Optional docs site served by pelago-server process
# export PELAGO_DOCS_ENABLED=true
# export PELAGO_DOCS_ADDR=127.0.0.1:4070
# export PELAGO_DOCS_DIR=docs
# export PELAGO_DOCS_TITLE='PelagoDB Presentation Docs'
